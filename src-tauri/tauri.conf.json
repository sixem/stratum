{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stratum",
  "version": "0.1.8",
  "identifier": "com.emy.stratum",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stratum",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "backgroundColor": "#0a0b10"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/thumbs/**", "$APPLOCALDATA/icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
